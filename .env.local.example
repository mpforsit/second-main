# Per docs/02-architecture.md §2.7. Copy to .env.local and fill in.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LLM providers (used from Step 4 onward)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Inngest (used from Step 5 onward)
# For local development, leave INNGEST_DEV=1 — the SDK then connects to the
# local inngest-cli dev server on http://localhost:8288. In production set
# the real EVENT_KEY + SIGNING_KEY and remove (or set =0) INNGEST_DEV.
INNGEST_DEV=1
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (Phase 2+)
RESEND_API_KEY=

# Observability (optional in MVP)
SENTRY_DSN=
